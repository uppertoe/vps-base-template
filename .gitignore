# Ansible
*.retry
ansible/inventory/!(production.example)   # ignore all inventories except the example

# Environment files
.env
*.env
!*.env.example
# Test fixtures contain no real credentials — always commit them
!molecule/backup/fixtures/**
!backup/tests/integration/fixtures/**

# Python / Ansible / Molecule
__pycache__/
*.pyc
.pytest_cache/
.molecule/
.cache/

# Audit reports (fetched from servers — may contain sensitive system info)
reports/

# Python venv
.venv/

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
