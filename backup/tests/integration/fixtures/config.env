# Integration test global config — no real credentials required.
# The restic repository uses local filesystem; no S3 access needed.

AWS_ACCESS_KEY_ID=test-key-not-real
AWS_SECRET_ACCESS_KEY=test-secret-not-real
AWS_DEFAULT_REGION=us-east-1

KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6

# No ALERT_EMAIL — suppresses all email attempts during tests.
ALERT_EMAIL=
NOTIFY_ON_SUCCESS=false
