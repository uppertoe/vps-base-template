# Test-only global backup config — no real credentials.
# Deployed to /etc/restic/config.env by the backup role during molecule test.

AWS_ACCESS_KEY_ID=test-key-not-real
AWS_SECRET_ACCESS_KEY=test-secret-not-real
AWS_DEFAULT_REGION=us-east-1

KEEP_DAILY=1
KEEP_WEEKLY=1
KEEP_MONTHLY=1

# No ALERT_EMAIL — suppresses all email attempts during tests.
ALERT_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=on
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=test@example.com

NOTIFY_ON_SUCCESS=false
