# Test-only service config — deployed to /etc/restic/services/ by backup role.
# Points to a local filesystem restic repo (no S3 needed for deployment tests).

SERVICE_NAME=testapp
RESTIC_REPOSITORY=/tmp/restic-test/testapp
RESTIC_PASSWORD=test-repo-password-not-real
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=testapp
DB_USER=testapp
DB_PASSWORD=testpass
STDIN_FILENAME=testapp-db.sql
VERIFY_QUERY=SELECT COUNT(*) FROM users
OPTIONAL=false
