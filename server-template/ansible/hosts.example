# Copy to ansible/hosts — gitignored since it contains server IP
# Usage:
#   ansible-playbook -i ansible/hosts scaffold/ansible/bootstrap.yml
#   ansible-playbook -i ansible/hosts scaffold/ansible/site.yml

[servers]
myserver ansible_host=YOUR_SERVER_IP

[servers:vars]
ansible_user=deploy
ansible_ssh_private_key_file=~/.ssh/id_ed25519
